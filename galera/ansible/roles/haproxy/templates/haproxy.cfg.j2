# HAProxy Configuration for MariaDB Galera Cluster
# Managed by Ansible - DO NOT EDIT MANUALLY

# =============================================================================
# Global Settings
# =============================================================================
global
    maxconn {{ haproxy_maxconn }}
    log /dev/log local0 info
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /var/lib/haproxy/stats mode 660 level admin
    user haproxy
    group haproxy
    daemon

# =============================================================================
# Default Settings
# =============================================================================
defaults
    mode tcp
    log global
    option tcplog
    option dontlognull
    option redispatch
    retries 3
    timeout connect {{ haproxy_connect_timeout }}
    timeout client {{ haproxy_client_timeout }}
    timeout server {{ haproxy_server_timeout }}
    timeout check 10s
    maxconn {{ haproxy_maxconn }}

# =============================================================================
# Stats UI
# http://{{ ansible_host }}:{{ haproxy_stats_port }}/stats
# =============================================================================
listen stats
    bind *:{{ haproxy_stats_port }}
    mode http
    stats enable
    stats uri /stats
    stats refresh 10s
    stats show-legends
    stats show-node
    stats admin if LOCALHOST
    stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_password }}

# =============================================================================
# Prometheus Metrics Endpoint
# http://{{ ansible_host }}:{{ haproxy_prometheus_port }}/metrics
# =============================================================================
frontend prometheus
    bind *:{{ haproxy_prometheus_port }}
    mode http
    http-request use-service prometheus-exporter if { path /metrics }
    no log

{% for cluster in galera_clusters %}
# =============================================================================
# Galera {{ cluster.name | upper }} Write Pool (Single-Master Pattern)
# Port: {{ cluster.haproxy_write_port }}
# =============================================================================
listen galera_{{ cluster.name }}_write
    bind *:{{ cluster.haproxy_write_port }}
    mode tcp
    option mysql-check user {{ haproxy_check_user }}
    balance first
    default-server inter {{ haproxy_check_interval }} fall {{ haproxy_check_fall }} rise {{ haproxy_check_rise }} on-marked-down shutdown-sessions maxconn {{ haproxy_server_maxconn }}
{% for host in groups[cluster.galera_group] %}
{% if loop.first %}
    server {{ host }} {{ hostvars[host].ansible_host }}:{{ galera_mysql_port | default(3306) }} check weight 1
{% else %}
    server {{ host }} {{ hostvars[host].ansible_host }}:{{ galera_mysql_port | default(3306) }} check weight 1 backup
{% endif %}
{% endfor %}

# =============================================================================
# Galera {{ cluster.name | upper }} Read Pool (Round-Robin)
# Port: {{ cluster.haproxy_read_port }}
# =============================================================================
listen galera_{{ cluster.name }}_read
    bind *:{{ cluster.haproxy_read_port }}
    mode tcp
    option mysql-check user {{ haproxy_check_user }}
    balance roundrobin
    default-server inter {{ haproxy_check_interval }} fall {{ haproxy_check_fall }} rise {{ haproxy_check_rise }} maxconn {{ haproxy_server_maxconn }}
{% for host in groups[cluster.galera_group] %}
    server {{ host }} {{ hostvars[host].ansible_host }}:{{ galera_mysql_port | default(3306) }} check weight 1
{% endfor %}

{% endfor %}
