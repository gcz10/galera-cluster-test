#!/bin/bash
# Galera Health Check Script for HAProxy
# Managed by Ansible - DO NOT EDIT MANUALLY
#
# Returns HTTP 200 if node is synced and ready
# Returns HTTP 503 if node is not ready

MYSQL_USER="{{ haproxy_check_user }}"
MYSQL_PASS="{{ haproxy_check_password }}"
MYSQL_HOST="127.0.0.1"
MYSQL_PORT="{{ galera_mysql_port | default(3306) }}"

# Check wsrep_local_state (4 = Synced)
SYNCED=$(mysql -u"$MYSQL_USER" -p"$MYSQL_PASS" -h"$MYSQL_HOST" -P"$MYSQL_PORT" \
    -Nse "SHOW GLOBAL STATUS LIKE 'wsrep_local_state'" 2>/dev/null | awk '{print $2}')

# Check wsrep_ready (ON = ready)
READY=$(mysql -u"$MYSQL_USER" -p"$MYSQL_PASS" -h"$MYSQL_HOST" -P"$MYSQL_PORT" \
    -Nse "SHOW GLOBAL STATUS LIKE 'wsrep_ready'" 2>/dev/null | awk '{print $2}')

# Check wsrep_cluster_status (Primary = in primary component)
CLUSTER=$(mysql -u"$MYSQL_USER" -p"$MYSQL_PASS" -h"$MYSQL_HOST" -P"$MYSQL_PORT" \
    -Nse "SHOW GLOBAL STATUS LIKE 'wsrep_cluster_status'" 2>/dev/null | awk '{print $2}')

if [ "$SYNCED" = "4" ] && [ "$READY" = "ON" ] && [ "$CLUSTER" = "Primary" ]; then
    # Node is healthy
    echo -e "HTTP/1.1 200 OK\r\n"
    echo -e "Content-Type: text/plain\r\n"
    echo -e "Connection: close\r\n"
    echo -e "\r\n"
    echo -e "Galera Node OK - Synced, Ready, Primary\r\n"
    exit 0
else
    # Node is not healthy
    echo -e "HTTP/1.1 503 Service Unavailable\r\n"
    echo -e "Content-Type: text/plain\r\n"
    echo -e "Connection: close\r\n"
    echo -e "\r\n"
    echo -e "Galera Node NOT Ready - State: $SYNCED, Ready: $READY, Cluster: $CLUSTER\r\n"
    exit 1
fi
