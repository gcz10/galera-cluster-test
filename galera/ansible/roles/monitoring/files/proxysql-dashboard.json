      "targets": [
        { "expr": "rate(proxysql_mysql_status_myhgm_myconnpoll_get[1m])", "legendFormat": "Get/s" },
        { "expr": "rate(proxysql_mysql_status_myhgm_myconnpoll_get_ok[1m])", "legendFormat": "Get OK/s" },
        { "expr": "rate(proxysql_mysql_status_myhgm_myconnpoll_push[1m])", "legendFormat": "Push/s" },
        { "expr": "rate(proxysql_mysql_status_myhgm_myconnpoll_destroy[1m])", "legendFormat": "Destroy/s" },
        { "expr": "rate(proxysql_mysql_status_myhgm_myconnpoll_reset[1m])", "legendFormat": "Reset/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },

    {
      "id": 107,
      "title": "Memory",
