      "targets": [
        { "expr": "rate(proxysql_mysql_status_connpool_get_conn_success[1m])", "legendFormat": "Success/s" },
        { "expr": "rate(proxysql_mysql_status_connpool_get_conn_failure[1m])", "legendFormat": "Failure/s" },
        { "expr": "rate(proxysql_mysql_status_connpool_get_conn_immediate[1m])", "legendFormat": "Immediate/s" },
        { "expr": "rate(proxysql_mysql_status_connpool_get_conn_latency_awareness[1m])", "legendFormat": "Latency Awareness/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
