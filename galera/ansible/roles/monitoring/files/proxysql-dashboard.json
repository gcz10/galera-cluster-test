      "targets": [
        { "expr": "proxysql_mysql_status_connpool_memory_bytes", "legendFormat": "ConnPool Memory" },
        { "expr": "proxysql_mysql_status_mysql_backend_buffers_bytes", "legendFormat": "Backend Buffers" },
        { "expr": "proxysql_mysql_status_mysql_frontend_buffers_bytes", "legendFormat": "Frontend Buffers" },
        { "expr": "proxysql_mysql_status_mysql_session_internal_bytes", "legendFormat": "Session Internal" },
        { "expr": "proxysql_mysql_status_sqlite3_memory_bytes", "legendFormat": "SQLite3" },
        { "expr": "proxysql_mysql_status_query_cache_memory_bytes", "legendFormat": "Query Cache" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
