{
  "id": null,
  "uid": "proxysql-overview",
  "title": "ProxySQL Overview",
  "tags": ["proxysql", "galera"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Client Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "proxysql_mysql_status_client_connections_connected", "legendFormat": "Connected" },
        { "expr": "proxysql_mysql_status_client_connections_non_idle", "legendFormat": "Non-Idle" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 2,
      "title": "Active Transactions",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "proxysql_mysql_status_active_transactions", "legendFormat": "Active TX" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "yellow", "value": 50 },
        { "color": "red", "value": 100 }
      ] } } }
    },
    {
      "id": 3,
      "title": "Questions (QPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(proxysql_mysql_status_questions[1m])", "legendFormat": "QPS" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 4,
      "title": "Server Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "proxysql_mysql_status_server_connections_connected", "legendFormat": "Connected" },
        { "expr": "rate(proxysql_mysql_status_server_connections_created[1m])", "legendFormat": "Created/s" },
        { "expr": "rate(proxysql_mysql_status_server_connections_aborted[1m])", "legendFormat": "Aborted/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "title": "Slow Queries",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(proxysql_mysql_status_slow_queries[1m])", "legendFormat": "Slow/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "yellow", "value": 1 },
        { "color": "red", "value": 10 }
      ] } } }
    },
    {
      "id": 6,
      "title": "Backend Traffic",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(proxysql_mysql_status_queries_backends_bytes_recv[1m])", "legendFormat": "Recv" },
        { "expr": "rate(proxysql_mysql_status_queries_backends_bytes_sent[1m])", "legendFormat": "Sent" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 7,
      "title": "Connection Pool - Queries by Hostgroup",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(proxysql_connection_pool_queries{hostgroup=\"10\"}[1m])", "legendFormat": "Writer HG10 - {{endpoint}}" },
        { "expr": "rate(proxysql_connection_pool_queries{hostgroup=\"12\"}[1m])", "legendFormat": "Reader HG12 - {{endpoint}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 8,
      "title": "Connection Pool - Used Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "proxysql_connection_pool_conn_used", "legendFormat": "Used - {{endpoint}} HG{{hostgroup}}" },
        { "expr": "proxysql_connection_pool_conn_free", "legendFormat": "Free - {{endpoint}} HG{{hostgroup}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 9,
      "title": "Connection Pool - Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "proxysql_connection_pool_latency_us / 1000", "legendFormat": "{{endpoint}} HG{{hostgroup}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 10,
      "title": "Connection Pool - Data Transfer",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(proxysql_connection_pool_bytes_data_recv[1m])", "legendFormat": "Recv - {{endpoint}}" },
        { "expr": "rate(proxysql_connection_pool_bytes_data_sent[1m])", "legendFormat": "Sent - {{endpoint}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 11,
      "title": "Stmt Execution Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(proxysql_mysql_status_com_frontend_stmt_execute[1m])", "legendFormat": "Frontend Execute/s" },
        { "expr": "rate(proxysql_mysql_status_com_backend_stmt_execute[1m])", "legendFormat": "Backend Execute/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 12,
      "title": "Monitor Health Checks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(proxysql_mysql_status_mysql_monitor_ping_check_ok[1m])", "legendFormat": "Ping OK/s" },
        { "expr": "rate(proxysql_mysql_status_mysql_monitor_connect_check_ok[1m])", "legendFormat": "Connect OK/s" },
        { "expr": "rate(proxysql_mysql_status_mysql_monitor_ping_check_err[1m])", "legendFormat": "Ping Err/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ],
  "schemaVersion": 39
}
