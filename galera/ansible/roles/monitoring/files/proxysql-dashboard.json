        { "expr": "proxysql_mysql_status_stmt_client_active_total", "legendFormat": "Client Active Total" },
        { "expr": "proxysql_mysql_status_stmt_client_active_unique", "legendFormat": "Client Active Unique" },
        { "expr": "proxysql_mysql_status_stmt_server_active_total", "legendFormat": "Server Active Total" },
        { "expr": "proxysql_mysql_status_stmt_server_active_unique", "legendFormat": "Server Active Unique" },
        { "expr": "proxysql_mysql_status_stmt_max_stmt_id", "legendFormat": "Max Stmt ID" }
